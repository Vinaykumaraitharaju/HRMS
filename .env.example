APP_NAME=Wavelynk
ENVIRONMENT=local
# Use Render Postgres in production. Render's postgres:// URL is supported automatically.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wavelynk
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
OFFICE_LATITUDE=12.9716
OFFICE_LONGITUDE=77.5946
OFFICE_RADIUS_METERS=250
